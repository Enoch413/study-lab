DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[DATABASE_PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require"

# Firebase client config for browser-side login state and ID token forwarding.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""

# Firebase Admin credentials for verifying Authorization: Bearer <Firebase ID token>.
# Prefer one JSON env var in deployment, or use the split service-account fields below.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# FIREBASE_PROJECT_ID=""
# FIREBASE_CLIENT_EMAIL=""
# FIREBASE_PRIVATE_KEY=""

# Optional: set to "true" only when you intentionally want local header-based dev fallback.
STUDY_LAB_ENABLE_DEV_FALLBACK="false"
